{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TurboFiles",
  "version": "0.1.5",
  "identifier": "io.xfusion.turbofiles",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TurboFiles",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "publisher": "xFusion",
    "homepage": "https://xfusion.io",
    "copyright": "© 2026 Martin Onami. Licensed under the MIT License.",
    "licenseFile": "../LICENSE",
    "shortDescription": "Modern SFTP/FTP/FTPS client",
    "longDescription": "TurboFiles is a fast, modern file-transfer client supporting SFTP, FTP and FTPS with a dual-pane interface, transfer queue and dark/light themes.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "deb": {
        "section": "net"
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDRjQ4RDI1NzQ0RUQ5RDIKUldUUzJVNTBKWTMwYlBucXV1YktvV1JQTm9ZZXBZWWhwQzJYYWFqeFBFM0pNNTg5ZWlRSmxSNmEK",
      "endpoints": [
        "https://github.com/MartinOnami/TurboFiles/releases/latest/download/latest.json"
      ]
    }
  }
}
